---
import '../styles/index.css';
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from "@vercel/speed-insights/astro"

const {
  title = 'Divyesh.dev',
  description = 'Exploring code, craft, and creativity',
  active = 'home'
} = Astro.props;

const navItems = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/posts', label: 'Posts', key: 'posts' },
  { href: '/bytes', label: 'Bytes', key: 'bytes' },
  { href: '/about', label: 'About', key: 'about' }
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <Analytics />
    <SpeedInsights />
  </head>
  <body class="bg-[#050505] text-white antialiased selection:bg-neutral-800 selection:text-white">
    <div class="min-h-screen flex flex-col">
      <header class="border-b border-white/10 sticky top-0 z-40 bg-[#050505]/95 backdrop-blur-md">
        <div class="flex justify-between items-center w-full px-6 md:px-12 max-w-5xl mx-auto h-20">
          <a href="/" class="flex flex-col items-start hover:opacity-85 transition-opacity cursor-pointer border-none bg-transparent p-0 text-left no-underline text-white">
            <span class="text-[9px] uppercase tracking-[0.3em] text-white/50 mb-0.5 leading-none font-bold">Available for hire</span>
            <span class="font-sans font-black text-xl md:text-2xl tracking-tighter text-white leading-none">
              DIVYESH<span class="text-white/35 italic font-light font-serif">.dev</span>
            </span>
          </a>

          <nav class="hidden md:flex items-center gap-8 h-full font-bold">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={{
                  'font-sans text-[11px] uppercase tracking-widest h-full flex items-center px-1 transition-all border-b': true,
                  'text-white font-black border-white': active === item.key,
                  'text-white/50 hover:text-white border-transparent': active !== item.key
                }}
              >
                {item.label}
              </a>
            ))}
          </nav>

          <div class="text-[10px] uppercase tracking-[0.3em] text-white/40 hidden sm:block">
            Crafted in Astro + React
          </div>
        </div>
      </header>

      <main class="flex-grow w-full max-w-7xl mx-auto px-6 md:px-12 py-10 flex flex-col gap-10">
        <slot />
      </main>

      <footer class="border-t border-white/10 bg-[#050505] mt-16 select-none">
        <div class="w-full py-12 px-6 md:px-12 max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="flex flex-col items-center md:items-start tracking-tight">
            <span class="font-sans font-black text-xl text-white tracking-tighter">
              DIVYESH<span class="text-white/35 italic font-light font-serif">.dev</span>
            </span>
            <p class="font-sans text-[10px] text-white/40 uppercase tracking-widest mt-1">
              © 2026 Divyesh. Built with Astro.
            </p>
          </div>

          <nav class="flex flex-wrap items-center justify-center gap-6">
            <a href="/posts" class="font-sans font-bold text-[10px] uppercase tracking-widest text-white/50 hover:text-white hover:underline decoration-white underline-offset-4 transition-colors">Posts</a>
            <a href="/bytes" class="font-sans font-bold text-[10px] uppercase tracking-widest text-white/50 hover:text-white hover:underline decoration-white underline-offset-4 transition-colors">Bytes</a>
            <a href="https://github.com/Divyesh-Kamalanaban" target="_blank" rel="noopener noreferrer" class="font-sans font-bold text-[10px] uppercase tracking-widest text-white/50 hover:text-white hover:underline decoration-white underline-offset-4 transition-colors">Github</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
